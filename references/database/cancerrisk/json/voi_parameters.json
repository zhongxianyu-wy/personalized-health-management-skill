{
  "metadata": {
    "source": "GLOBOCAN 2022 + survival_data.json + detection_performance.json + VoI理论框架",
    "version": "2.0.0",
    "update_date": "2026-04-09",
    "note": "VoI(检测) = P(阴性)×ΔT_阴性 + P(阳性)×ΔT_阳性，选期望生存时间增益最大的检测",
    "formula": {
      "voi": "VoI = P_neg × delta_T_neg + P_pos × delta_T_pos",
      "P_neg": "P(检测阴性) = 1 - prior_risk × sensitivity",
      "P_pos": "P(检测阳性) = prior_risk × sensitivity + (1-prior_risk) × (1-specificity)",
      "delta_T_neg": "阴性结果对行为改变的影响（降低焦虑/减少不必要复查）",
      "delta_T_pos": "阳性结果→早期干预的生存时间增益"
    }
  },
