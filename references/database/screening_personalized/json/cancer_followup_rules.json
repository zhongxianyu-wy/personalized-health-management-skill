  "source_version": "2.0.0 (2026-04-09)",
  "last_updated": "2026-06-25",
  "note": "从源 MD 机械编译的确定性查表（cancer_id × risk_tier → 复查周期+方法；可疑发现代号 → 复查；阳性 → MDT）。v2.0.0 build_section_artifacts.py 用它生成 timeline_tiers 骨架。文案/措辞留 LLM，本表只含数值与结构。",

  "risk_tiers": {
    "very_low":  {"label": "极低风险", "max_posterior": 0.001},
    "low":       {"label": "低风险",   "max_posterior": 0.005},
    "medium":    {"label": "中等风险", "max_posterior": 0.02},
    "high":      {"label": "高风险",   "max_posterior": 0.05},
    "very_high": {"label": "极高风险", "max_posterior": 1.0}
  },

  "timeline_thresholds": {
    "priority":  {"window": "1-2 周内",  "min_posterior": 0.01,  "condition": "health_summary 较严重 OR 癌症后验 > 1%"},
    "important": {"window": "1 个月内",  "min_posterior": 0.005, "max_posterior": 0.01, "condition": "health_summary 中等风险 OR 癌症后验 0.5%-1%"},
    "maintain":  {"window": "3-6 个月内", "condition": "筛查缺口（指南应到年限但未检测）"}
  },

